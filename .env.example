# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
DISABLE_RATE_LIMIT=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
ACCESS_TOKEN_SECRET=your-access-token-secret-min-32-chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
VERIFICATION_TOKEN_SECRET=your-verification-secret
RESET_TOKEN_SECRET=your-reset-secret

# AWS
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=your-bucket-name
MEDIA_CDN_URL=https://media.yourdomain.com
SES_FROM_EMAIL=noreply@yourdomain.com

# IVS (Live Streaming)
AWS_IVS_REGION=eu-west-1
AWS_IVS_CHANNEL_TYPE=BASIC
AWS_IVS_RECORDING_CONFIG_ARN=arn:aws:ivs:region:account:recording-configuration/abc123

# Redis (Socket.IO horizontal scaling — optional; single-instance works without it)
# AWS ElastiCache: rediss://your-cluster.cache.amazonaws.com:6380
# Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Firebase Admin (FCM push notifications for live tour alerts)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEF...\n-----END PRIVATE KEY-----\n"

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Email (choose SES or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Payment gateways
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxx
KORAPAY_SECRET_KEY=sk_test_xxxxxxxxxx

# SMS
SENDCHAMP_KEY=sendchamp_live_xxxxxxxxxx
SENDCHAMP_SENDER_ID=Keyvia

# App info
APP_NAME=Keyvia
SUPPORT_EMAIL=support@yourdomain.com
LOGO_URL=https://your-cdn.com/logo.png
